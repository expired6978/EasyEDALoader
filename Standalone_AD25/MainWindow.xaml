<Window x:Class="Standalone_AD25.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Standalone AD25 Sandbox" Height="800" Width="1200">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Barre de recherche LCSC -->
        <StackPanel Orientation="Horizontal" Margin="10">
            <TextBox x:Name="SearchBox"
                     Width="400"
                     Height="30"
                     KeyDown="SearchBox_KeyDown"
                     Margin="0,0,10,0"
                     VerticalContentAlignment="Center"
                     FontSize="14"/>

            <Button x:Name="BtnSearch"
                    Content="Search"
                    Width="100"
                    Height="30"
                    Click="BtnSearch_Click"/>
        </StackPanel>

        <!-- Bouton pour ouvrir le WebView initial -->
        <Button x:Name="BtnBrowser"
                Content="Open LCSC Browser"
                Margin="10"
                Padding="10"
                Width="200"
                Height="40"
                Grid.Row="1"
                Click="BtnBrowser_Click"/>

        <!-- Bouton extract PDF -->
        <Button x:Name="BtnExtractPdf"
                Content="Extract Datasheet"
                Width="120"
                Height="30"
                Margin="10"
                Grid.Row="1"
                HorizontalAlignment="Right"
                Click="BtnExtractPdf_Click"/>

        <Button x:Name="BtnBack"
        Content="◀ Retour"
        Width="100"
        Height="30"
        Margin="10"
        Grid.Row="1"
        HorizontalAlignment="Left"
        Click="BtnBack_Click"/>



        <!-- Hôte où s'affiche le LCSCView -->
        <ContentControl x:Name="ContentHost"
                        Grid.Row="2" />
    </Grid>
</Window>

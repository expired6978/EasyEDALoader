<Window x:Class="Standalone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:h="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf"
        xmlns:local="clr-namespace:Standalone"
        mc:Ignorable="d"
        Title="MainWindow" Height="455" Width="483" Background="#FF313131">
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBox x:Name="PartId" TextWrapping="Wrap" Text="C7419871" Grid.Row="0" Margin="10,10,10,10" Background="#FF7F7F7F" Uid="{Binding Text, ElementName=PartId}"/>
        <Viewbox x:Name="PreviewBox" Grid.Row="1" MinHeight="50" HorizontalAlignment="Center" Stretch="Uniform" Margin="10,0,10,0">
            <Image x:Name="Thumbnail" Height="50" Width="50"/>
        </Viewbox>
        <ScrollViewer x:Name="SymbolCanvasView" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Grid.Row="2" Margin="10,10,10,10" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" Background="Black">
            <Canvas x:Name="SymbolCanvas" Height="100" Width="100" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        </ScrollViewer>
        <ScrollViewer x:Name="FootprintCanvasView" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Grid.Row="3" Margin="10,10,10,10" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" Background="Black">
            <Canvas x:Name="FootprintCanvas" Height="100" Width="100" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        </ScrollViewer>
        <h:HelixViewport3D x:Name="ModelView" Grid.Row="4" HorizontalAlignment="Stretch" Margin="10,0,10,0">
            <h:DefaultLights />
        </h:HelixViewport3D>
        <StackPanel HorizontalAlignment="Left" Margin="10,10,0,10" Orientation="Horizontal" Grid.Row="5" VerticalAlignment="Center">
            <Button x:Name="LoadButton" Content="Load" Height="28" Width="81" Background="#FF424242" Click="LoadButton_Click"/>
            <Button x:Name="ModelButton" Content="Step..." Background="#FF424242" Margin="10,0,0,0" Width="65" IsEnabled="False" Click="ModelButton_Click"/>
            <Button x:Name="ObjButton" Content="Obj..." Background="#FF424242" Margin="10,0,0,0" Width="65" IsEnabled="False" Click="ObjModelButton_Click"/>
        </StackPanel>


    </Grid>
</Window>

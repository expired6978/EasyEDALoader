<Window x:Class="EasyEDA_Loader.DialogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    mc:Ignorable="d"
    Title="EasyEDA Component Loader" 
    Height="600" 
    Width="1100"
    MinHeight="500"
    MinWidth="900"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="False"
    ResizeMode="CanResize"
    Loaded="Window_Loaded">
<Window.Resources>
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
    </Style>
</Window.Resources>
<Grid x:Name="mainGrid">
<Grid.ColumnDefinitions>
    <ColumnDefinition Width="*"/>
    <ColumnDefinition Width="350"/>
</Grid.ColumnDefinitions>
<Grid.RowDefinitions>
    <RowDefinition Height="Auto"/>
    <RowDefinition Height="*"/>
    <RowDefinition Height="Auto"/>
</Grid.RowDefinitions>

        <!-- Search Panel -->
        <Border Grid.Row="0" Grid.Column="0" Padding="12,15,12,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                           Text="Enter part number to search (e.g. C2040):"
                           Margin="0,0,0,8"/>

                <dxe:TextEdit x:Name="searchTextBox" 
                         Grid.Row="1" 
                         Grid.Column="0"
                         Margin="0,0,8,0"
                         VerticalContentAlignment="Center"
                         Height="24"
                         KeyDown="SearchTextBox_KeyDown"/>

                <dx:SimpleButton x:Name="searchButton" 
                        Grid.Row="1" 
                        Grid.Column="1"
                        Content="Search"
                        Width="75"
                        Height="24"
                        Click="SearchButton_Click"/>
            </Grid>
        </Border>

        <!-- Results Grid -->
        <dxg:GridControl x:Name="resultsGrid" 
                         Grid.Row="1"
                         Grid.Column="0"
                         Margin="12,0,12,10"
                         AutoGenerateColumns="None"
                         SelectionMode="Row"
                         CurrentItemChanged="ResultsGrid_CurrentItemChanged">
            <dxg:GridControl.View>
                <dxg:TableView ShowGroupPanel="False"
                               AllowEditing="False"
                               ShowIndicator="False"
                               NavigationStyle="Row"
                               AutoWidth="False"
                               AllowColumnMoving="False"
                               ShowColumnHeaders="True"
                               ShowAutoFilterRow="False"/>
            </dxg:GridControl.View>
            
            <dxg:GridControl.Columns>
                <dxg:GridColumn Header="" 
                                FieldName="AddToLibrary" 
                                Width="40"
                                MinWidth="40"
                                MaxWidth="40"
                                AllowResizing="False"
                                FixedWidth="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <dxe:CheckEdit IsChecked="{Binding Path=RowData.Row.AddToLibrary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>

                <dxg:GridColumn Header="FP" 
                                FieldName="HasFootprint" 
                                Width="40"
                                MinWidth="40"
                                MaxWidth="40"
                                AllowResizing="False"
                                FixedWidth="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <dxe:CheckEdit IsChecked="{Binding Path=RowData.Row.HasFootprint, Mode=OneWay}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsEnabled="False"/>
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>

                <dxg:GridColumn Header="3D" 
                                FieldName="Has3d" 
                                Width="40"
                                MinWidth="40"
                                MaxWidth="40"
                                AllowResizing="False"
                                FixedWidth="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <dxe:CheckEdit IsChecked="{Binding Path=RowData.Row.Has3d, Mode=OneWay}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsEnabled="False"/>
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>

                <dxg:GridColumn Header="Name" 
                                FieldName="Name" 
                                Width="150"
                                MinWidth="100"/>

                <dxg:GridColumn Header="Description" 
                                FieldName="Description" 
                                Width="*"
                                MinWidth="200"/>
            </dxg:GridControl.Columns>
        </dxg:GridControl>

        <!-- Bottom Panel with Options and Buttons -->
        <Grid Grid.Row="2" Grid.Column="0" Margin="12,0,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <dxe:CheckEdit x:Name="closeDocumentsCheckBox" 
                          Content="Close library documents after adding"
                          VerticalAlignment="Center"
                          Margin="0,0,20,0"/>
                <dxe:CheckEdit x:Name="placeInSchematicCheckBox" 
                          Content="Place in schematic"
                          IsChecked="True"
                          VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <dx:SimpleButton x:Name="saveModelButton" 
                        Content="Save Model..."
                        Width="100"
                        Height="24"
                        Margin="0,0,8,0"
                        IsEnabled="False"
                        Click="SaveModelButton_Click"/>
                <dx:SimpleButton x:Name="addToLibraryButton" 
                        Content="Add to Library"
                        Width="120"
                        Height="24"
                        Margin="0,0,8,0"
                        IsEnabled="False"
                        Click="AddToLibraryButton_Click"/>
                <dx:SimpleButton x:Name="cancelButton" 
                        Content="Cancel"
                        Width="75"
                        Height="24"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- Side Panel with Preview -->
        <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" 
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" 
                BorderThickness="1,0,0,0"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="Preview" 
                           FontSize="14" 
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <!-- Thumbnail -->
                <Viewbox x:Name="thumbnailViewbox" Grid.Row="1" 
                         MinHeight="50" 
                         HorizontalAlignment="Center" 
                         Stretch="Uniform" 
                         Margin="0,0,0,10">
                    <Image x:Name="thumbnailImage" Height="50" Width="50"/>
                </Viewbox>

                <!-- Symbol Canvas -->
                <ScrollViewer x:Name="symbolCanvasView" 
                              Grid.Row="2"
                              VerticalAlignment="Stretch" 
                              HorizontalAlignment="Stretch" 
                              Margin="0,0,0,10" 
                              HorizontalScrollBarVisibility="Hidden" 
                              VerticalScrollBarVisibility="Hidden" 
                              Background="Black">
                    <Canvas x:Name="symbolCanvas" Height="100" Width="100" 
                            HorizontalAlignment="Left" VerticalAlignment="Top"/>
                </ScrollViewer>

                <!-- Footprint Canvas -->
                <ScrollViewer x:Name="footprintCanvasView" 
                              Grid.Row="3"
                              VerticalAlignment="Stretch" 
                              HorizontalAlignment="Stretch" 
                              HorizontalScrollBarVisibility="Hidden" 
                              VerticalScrollBarVisibility="Hidden" 
                              Background="Black">
                    <Canvas x:Name="footprintCanvas" Height="100" Width="100" 
                            HorizontalAlignment="Left" VerticalAlignment="Top"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
